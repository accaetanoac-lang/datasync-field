{
  "family": "datasync-field-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::496795891165:role/datasync-field-ecs-execution-role",
  "containerDefinitions": [
    {
      "name": "datasync-field-api",
      "image": "496795891165.dkr.ecr.us-east-1.amazonaws.com/datasync-field-api:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 3001, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "NODE_ENV",      "value": "production" },
        { "name": "PORT",         "value": "3001" },
        { "name": "DATABASE_URL", "value": "PLACEHOLDER" },
        { "name": "JWT_SECRET",   "value": "PLACEHOLDER" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/datasync-field-api",
          "awslogs-region":        "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
